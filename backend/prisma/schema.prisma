// basic setup for now — expand models/migrations as the app grows

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  Admin
  Instructor
  Student
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]
}

enum UnitType {
  video
  text
  attachment
  quiz
}

enum QuizQuestionMode {
  single
  multi
}

enum EnrollmentType {
  open
  closed
  invite_only
  paid
}

// per-student row 
enum EnrollmentKind {
  free
  paid
  honor
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique // one account per email
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  roleId       String   @map("role_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role              Role    @relation(fields: [roleId], references: [id])
  instructedCourses Course[] @relation("InstructorCourses")
  enrollments       Enrollment[]
  unitProgress      UnitProgress[]
  quizAttempts      QuizAttempt[]
  certificates      Certificate[]
  refreshTokens     RefreshToken[]
}

// storing token hash in DB for now
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  published    Boolean  @default(false)
  instructorId String   @map("instructor_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  instructor User        @relation("InstructorCourses", fields: [instructorId], references: [id])
  sections   Section[]
  courseRuns CourseRun[]
}

model Section {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subsections Subsection[]
}

model Subsection {
  id         String   @id @default(uuid()) @db.Uuid
  sectionId  String   @map("section_id") @db.Uuid
  title      String
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  units   Unit[]
}

model Unit {
  id           String   @id @default(uuid()) @db.Uuid
  subsectionId String   @map("subsection_id") @db.Uuid
  type         UnitType
  title        String
  orderIndex   Int      @default(0) @map("order_index")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subsection Subsection @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  progress   UnitProgress[]
  quiz       Quiz?
}

model UnitProgress {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  unitId             String   @map("unit_id") @db.Uuid
  lastWatchedSeconds Int      @default(0) @map("last_watched_seconds")
  completionPercent Float    @map("completion_percent")
  completed          Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([userId])
}

model CourseRun {
  id             String         @id @default(uuid()) @db.Uuid
  courseId       String         @map("course_id") @db.Uuid
  runName        String         @map("run_name")
  startDate      DateTime       @map("start_date")
  endDate        DateTime       @map("end_date")
  enrollmentType EnrollmentType @map("enrollment_type")
  price          Decimal        @db.Decimal(12, 2)
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
  gradingConfig  GradingConfig?
  certificates   Certificate[]

  @@index([courseId])
}

model Enrollment {
  id             String         @id @default(uuid()) @db.Uuid
  courseRunId    String         @map("course_run_id") @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  kind           EnrollmentKind @default(free)
  isActive       Boolean        @default(true) @map("is_active")
  gradeWeighted  Float?         @map("grade_weighted")
  gradePassed    Boolean?       @map("grade_passed")
  gradeBreakdown Json?          @map("grade_breakdown")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  courseRun   CourseRun    @relation(fields: [courseRunId], references: [id], onDelete: Restrict)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate?

  // added constraint to avoid duplicate enrollments (one row per user per run; soft-unenroll uses is_active)
  @@unique([courseRunId, userId])
  @@index([courseRunId])
  @@index([userId])
}

model Certificate {
  id                    String   @id @default(uuid()) @db.Uuid
  enrollmentId          String   @unique @map("enrollment_id") @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  courseRunId           String   @map("course_run_id") @db.Uuid
  verificationCode      String   @unique @map("verification_code") // globally unique for public verify
  courseTitleSnapshot   String   @map("course_title_snapshot")
  runNameSnapshot       String   @map("run_name_snapshot")
  recipientNameSnapshot String   @map("recipient_name_snapshot")
  issuedAt              DateTime @default(now()) @map("issued_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseRun  CourseRun  @relation(fields: [courseRunId], references: [id], onDelete: Restrict)

  @@index([courseRunId])
  @@index([userId])
}

model GradingConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  courseRunId          String   @unique @map("course_run_id") @db.Uuid
  weights              Json
  passThresholdPercent Float    @map("pass_threshold_percent")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  courseRun CourseRun @relation(fields: [courseRunId], references: [id], onDelete: Cascade)
}

model Quiz {
  id          String   @id @default(uuid()) @db.Uuid
  unitId      String   @unique @map("unit_id") @db.Uuid
  title       String
  maxAttempts Int      @map("max_attempts")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  unit      Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id               String           @id @default(uuid()) @db.Uuid
  quizId           String           @map("quiz_id") @db.Uuid
  prompt           String
  orderIndex       Int              @map("order_index")
  mode             QuizQuestionMode
  options          Json
  correctOptionIds Json             @map("correct_option_ids")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id           String   @id @default(uuid()) @db.Uuid
  quizId       String   @map("quiz_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  answers      Json
  scorePercent Float    @map("score_percent")
  createdAt    DateTime @default(now()) @map("created_at")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId, userId])
  @@index([userId])
}
